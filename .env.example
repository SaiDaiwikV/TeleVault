# Copy this file to `.env` and fill in your real values. Never commit .env.
#
# SECURITY: TELEGRAM_API_ID / TELEGRAM_API_HASH are the SERVER OPERATOR's
# developer credentials for the Telegram account that backs ALL storage. They
# are NOT per-user secrets and must never be exposed to the browser or entered
# in the web UI — the frontend only ever reads a connected/not-connected
# *status* via /api/telegram/check. Keep them server-side, in this file only.
# Get them from https://my.telegram.org -> API development tools.
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# One session name, or a comma-separated list for session pooling (Phase 4):
# spreading uploads across multiple logged-in accounts to stay further below
# Telegram's per-account flood-wait limits. Each session needs its own login
# (run scripts/check_telegram_config.py) and all must be members of the same
# storage channel.
TELEGRAM_SESSION_NAMES=televault

# Leave blank on first run; the app/spike will create a private channel and
# save its ID back into this file automatically.
TELEGRAM_STORAGE_CHANNEL_ID=

# App settings
TELEVAULT_ENV=development
# SQLite by default. For PostgreSQL:
#   DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/televault
DATABASE_URL=sqlite:///televault.db
TELEVAULT_CHUNK_SIZE=16777216
TELEVAULT_TOKEN_TTL_DAYS=30
# Max size of a single upload in bytes (default 2 GiB = Telethon's per-file
# limit for a non-Premium account). Set to 0 to disable the cap.
TELEVAULT_MAX_UPLOAD_BYTES=2147483648

# Comma-separated browser origins allowed to call the API (needed only if the
# React frontend is served from a different origin than the API, e.g. during
# `npm run dev`). Leave blank in production if the built frontend is served
# by this same FastAPI app.
TELEVAULT_CORS_ORIGINS=http://localhost:5173

# Auth brute-force protection
TELEVAULT_AUTH_RATE_LIMIT=10
TELEVAULT_AUTH_RATE_WINDOW=300

# Share links
TELEVAULT_SHARE_DEFAULT_HOURS=24
TELEVAULT_SHARE_MAX_HOURS=720

# ── OAuth social login ─────────────────────────────────────────────────────
# Public base URL of this TeleVault instance (no trailing slash).
# Used to build the OAuth callback URL: <TELEVAULT_APP_BASE_URL>/api/auth/oauth/<provider>/callback
# Register this callback URL at each provider's developer console.
TELEVAULT_APP_BASE_URL=http://localhost:8000

# Google OAuth 2.0
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI to add: <TELEVAULT_APP_BASE_URL>/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth App
# Create at: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: <TELEVAULT_APP_BASE_URL>/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
